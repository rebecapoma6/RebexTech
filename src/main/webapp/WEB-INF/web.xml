<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>RegistroController</servlet-name>
        <servlet-class>es.rebextech.controllers.RegistroController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CarritoController</servlet-name>
        <servlet-class>es.rebextech.controllers.CarritoController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CatalogoController</servlet-name>
        <servlet-class>es.rebextech.controllers.CatalogoController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FrontController</servlet-name>
        <servlet-class>es.rebextech.controllers.FrontController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UsuarioController</servlet-name>
        <servlet-class>es.rebextech.controllers.UsuarioController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AjaxController</servlet-name>
        <servlet-class>es.rebextech.controllers.AjaxController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroController</servlet-name>
        <url-pattern>/RegistroController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CarritoController</servlet-name>
        <url-pattern>/CarritoController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CatalogoController</servlet-name>
        <url-pattern>/CatalogoController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FrontController</servlet-name>
        <url-pattern>/FrontController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UsuarioController</servlet-name>
        <url-pattern>/UsuarioController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AjaxController</servlet-name>
        <url-pattern>/AjaxController</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>FrontController</welcome-file>
    </welcome-file-list>
    <error-page>
        <error-code>404</error-code>
        <location>/ERROR/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/ERROR/error500.jsp</location>
    </error-page>
    <resource-ref>
        <description>Conexion a BD RebexTech</description>
        <res-ref-name>jdbc/RebexTechDS</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
</web-app>
